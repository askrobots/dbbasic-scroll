# Dev convenience — the Connect screen pre-fills from this file if present.
# Copy to .env and fill in your values. NEVER commit .env.

# Your object server (see https://github.com/askrobots/dbbasic-object-server)
OBJECT_SERVER_URL=http://127.0.0.1:8000

# Optional platform API for askrobots.com collections
#PLATFORM_URL=https://askrobots.com

# Deployment admin token (or sign in with email + password instead)
DBBASIC_ADMIN_TOKEN=

# Optional: OpenAI key for the AI Create screen (stored on-device)
#OPENAI_API_KEY=
